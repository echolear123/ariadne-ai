{
  "name": "doc_stats",
  "version": "1.0.0",
  "description": "文档统计工具 - 文本分析、字数统计、关键词提取",
  "author": "AI Agent",
  "tools": [
    {
      "name": "word_count",
      "description": "统计文本字数/字符数/段落数",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {"type": "string", "description": "待统计文本"}
        },
        "required": ["text"]
      }
    },
    {
      "name": "extract_keywords",
      "description": "提取文本中的高频关键词 (TF 统计)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {"type": "string", "description": "待分析文本"},
          "top_n": {"type": "integer", "description": "返回前 N 个关键词 (默认 10)"}
        },
        "required": ["text"]
      }
    },
    {
      "name": "text_summary",
      "description": "快速摘要: 取文本前/中/后各一段",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {"type": "string", "description": "待摘要文本"}
        },
        "required": ["text"]
      }
    }
  ]
}
