# Ariadne AI 环境变量配置
# 复制此文件为 .env 并填入真实值

# SiliconFlow API (https://siliconflow.cn)
SF_API_KEY=sk-your-api-key-here
SF_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3-8B
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Web 服务
WEB_HOST=0.0.0.0
WEB_PORT=7860

# 默认登录账号: admin / admin123 (修改 config.py 中 USERS 字典可增删用户)
